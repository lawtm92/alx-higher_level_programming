#!/bin/bash

# check if PYFILE environment variable is set
if [ -z "$PYFILE" ]; then
    echo "Error: PYFILE environment variable is not set"
    exit 1
fi

# check if PYFILE file exists
if [ ! -f "$PYFILE" ]; then
    echo "Error: PYFILE file does not exist"
    exit 1
fi

# run the Python script
python "$PYFILE"
